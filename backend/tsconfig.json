{
  "compilerOptions": {
    "lib": ["es5", "es6"],
    "target": "es2017",
    "module": "Node16",
    "moduleResolution": "Node16",
    "isolatedModules": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
