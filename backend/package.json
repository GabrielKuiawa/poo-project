{
  "name": "@mood-board/backend",
  "version": "0.0.1",
  "description": "API da plataforma de inspiração visual.",
  "type": "commonjs",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.1",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.6",
    "reflect-metadata": "^0.2.2",
    "typeorm": "0.3.30"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node --files src/server.ts",
    "clean": "node -e \"require('node:fs').rmSync('build', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.build.json",
    "start": "node build/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.js\" \"*.json\" \"*.yml\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.js\" \"*.json\" \"*.yml\" \"*.md\"",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "npm run typeorm -- migration:run -d src/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/data-source.ts",
    "seed": "node build/seed/run.js",
    "seed:dev": "ts-node --files src/seed/run.ts",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit",
    "test:integration": "jest --runInBand tests/integration",
    "test:e2e": "jest --runInBand tests/e2e",
    "test:db:up": "docker compose -f docker-compose.test.yml --profile test up -d --wait mysql-test",
    "test:db:down": "docker compose -f docker-compose.test.yml --profile test down -v"
  }
}
