PORT=3000
CORS_ORIGIN=http://localhost:5173,https://mood-board.gabizin.me

# A App Platform fornece esta URL ao anexar um Managed Database.
# Quando preenchida, ela substitui as variáveis DB_* abaixo e habilita SSL.
DATABASE_URL=

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_SSL=false

# Usada somente pelo MySQL de desenvolvimento no Docker Compose.
MYSQL_ROOT_PASSWORD=

JWT_SECRET=

# DigitalOcean Spaces
SPACES_PREFIX=dev
SPACES_REGION=nyc3
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_BUCKET=mood-board-media
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_PUBLIC_URL=https://mood-board-media.nyc3.cdn.digitaloceanspaces.com

# Senha privada dos demais usuários gerados pelo seed.
SEED_USER_PASSWORD=

# Banco isolado para testes de integração
DB_TEST_PORT=3307
DB_TEST_DATABASE=image_management_test
