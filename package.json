{
  "name": "mood-board",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo da plataforma de inspiração visual.",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "typecheck": "npm --prefix backend run typecheck && npm --prefix frontend run typecheck",
    "lint": "npm --prefix backend run lint && npm --prefix frontend run lint",
    "format:check": "npm --prefix backend run format:check",
    "test": "npm --prefix backend test",
    "test:unit": "npm --prefix backend run test:unit",
    "test:integration": "npm --prefix backend run test:integration",
    "test:e2e": "npm --prefix backend run test:e2e",
    "test:db:up": "npm --prefix backend run test:db:up",
    "test:db:down": "npm --prefix backend run test:db:down",
    "migration:run": "npm --prefix backend run migration:run",
    "migration:revert": "npm --prefix backend run migration:revert",
    "db:up": "docker compose --env-file backend/.env up -d mysql",
    "db:down": "docker compose --env-file backend/.env down",
    "docker:up": "docker compose --env-file backend/.env --env-file frontend/.env up --build",
    "docker:down": "docker compose --env-file backend/.env --env-file frontend/.env down",
    "docker:ps": "docker compose --env-file backend/.env --env-file frontend/.env ps",
    "docker:logs": "docker compose --env-file backend/.env --env-file frontend/.env logs -f"
  }
}
